# =============================================================================
# DayZ Project — Variáveis de ambiente (Linux / Oracle VPS)
# =============================================================================
# Gerado automaticamente por configure_environment.sh na primeira execução:
#   /home/ubuntu/dayz/.env
#
# Cópia manual (se necessário):
#   cp deploy/linux/.env.example /home/ubuntu/dayz/.env
# =============================================================================

# -----------------------------------------------------------------------------
# Diretórios
# -----------------------------------------------------------------------------

# DAYZ_HOME — Diretório raiz de toda a infraestrutura DayZ na VPS
DAYZ_HOME=/home/ubuntu/dayz

# DAYZ_SERVER_DIR — Instalação do DayZ Dedicated Server (binários via SteamCMD)
DAYZ_SERVER_DIR=/home/ubuntu/dayz/server

# PROJECT_DIR — Repositório Git clonado (monorepo DayZ-Project)
PROJECT_DIR=/home/ubuntu/dayz/project

# PROFILE_DIR — Perfis de runtime do servidor (VPPAdminTools, logs, etc.)
PROFILE_DIR=/home/ubuntu/dayz/profiles

# STEAMCMD_DIR — Instalação do cliente SteamCMD
STEAMCMD_DIR=/home/ubuntu/dayz/steamcmd

# DAYZ_BACKUPS_DIR — Backups locais do servidor
DAYZ_BACKUPS_DIR=/home/ubuntu/dayz/backups

# DAYZ_LOGS_DIR — Logs centralizados (stdout do start.sh + symlinks)
DAYZ_LOGS_DIR=/home/ubuntu/dayz/logs

# -----------------------------------------------------------------------------
# Steam / SteamCMD
# -----------------------------------------------------------------------------

# DAYZ_APP_ID — Steam App ID do DayZ Dedicated Server (não alterar)
DAYZ_APP_ID=223350

# STEAM_PLATFORM — Plataforma dos binários baixados pelo SteamCMD (windows = .exe)
STEAM_PLATFORM=windows

# STEAM_USERNAME — Login da conta Steam que possui licença do DayZ Server
# OBRIGATÓRIO: login anonymous NÃO funciona para o App ID 223350
# A senha NÃO é armazenada neste arquivo — solicitada interativamente na
# primeira instalação. Atualizações usam autenticação em cache do SteamCMD.
STEAM_USERNAME=

# -----------------------------------------------------------------------------
# Wine
# -----------------------------------------------------------------------------

# WINEPREFIX — Prefixo Wine dedicado ao DayZ (separado do ~/.wine padrão)
WINEPREFIX=/home/ubuntu/.wine-dayz

# WINEDEBUG — Nível de debug do Wine (-all desativa ruído nos logs)
WINEDEBUG=-all

# WINEARCH — Arquitetura do prefixo Wine (win64 para DayZ Server 64-bit)
WINEARCH=win64

# -----------------------------------------------------------------------------
# Servidor DayZ
# -----------------------------------------------------------------------------

# DAYZ_USER — Usuário Linux que executa o servidor e o SteamCMD
DAYZ_USER=ubuntu

# DAYZ_PORT — Porta UDP do servidor
DAYZ_PORT=2302

# DAYZ_CONFIG — Arquivo de configuração principal do servidor
DAYZ_CONFIG=serverDZ.cfg

# DAYZ_HOSTNAME — Nome exibido no browser de servidores
DAYZ_HOSTNAME="DayZ Project DEV"

# DAYZ_EXTRA_ARGS — Parâmetros extras passados ao DayZServer_x64.exe
DAYZ_EXTRA_ARGS=-freezecheck -adminlog -dologs

# DAYZ_MODS — Mods do cliente (futuro — deixar vazio por enquanto)
DAYZ_MODS=

# DAYZ_SERVER_MODS — Server mods (futuro — deixar vazio por enquanto)
DAYZ_SERVER_MODS=

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------

# GIT_REPO_URL — URL do repositório para clone automático no bootstrap
GIT_REPO_URL=https://github.com/SEU_USUARIO/dayz-project.git

# GIT_BRANCH — Branch padrão para clone e deploy
GIT_BRANCH=main

# -----------------------------------------------------------------------------
# Operação
# -----------------------------------------------------------------------------

# DAYZ_PID_FILE — Arquivo com PID do processo do servidor
DAYZ_PID_FILE=/home/ubuntu/dayz/dayz-server.pid

# DAYZ_TMUX_SESSION — Nome da sessão tmux do servidor
DAYZ_TMUX_SESSION=dayz-server

# DAYZ_MAIN_LOG — Log principal de stdout do servidor
DAYZ_MAIN_LOG=/home/ubuntu/dayz/logs/dayz-server.log

# -----------------------------------------------------------------------------
# Aliases legados (compatibilidade com scripts anteriores — não remover)
# -----------------------------------------------------------------------------
DAYZ_BASE=/home/ubuntu/dayz
DAYZ_PROJECT_DIR=/home/ubuntu/dayz/project
DAYZ_PROFILES_DIR=/home/ubuntu/dayz/profiles
STEAMCMD_PLATFORM=windows
